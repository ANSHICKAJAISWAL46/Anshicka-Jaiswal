data<-read_csv("/Users/vaishallihsingh/Downloads/diabetes_risk_dataset.csv")
data <- data %>% mutate(age_group = cut(Age,breaks = c(0, 20, 30, 40, 50, 60, 70, 100),labels = c("0-20", "21-30", "31-40", "41-50","51-60", "61-70", "71+"),right = TRUE))
data <- data %>% mutate(age_group = cut(age,breaks = c(0, 20, 30, 40, 50, 60, 70, 100),labels = c("0-20", "21-30", "31-40", "41-50","51-60", "61-70", "71+"),right = TRUE))
age_risk <- data %>%group_by(age_group) %>% summarize(mean_risk = mean(DiabetesRiskScore, na.rm = TRUE))
age_risk <- data %>%group_by(age_group) %>% summarize(mean_risk = mean(diabetes_risk_score, na.rm = TRUE))
highest_age_group <- age_risk %>%arrange(desc(mean_risk)) %>%slice(1)
print(highest_age_group)
data <- data %>%  mutate(bmi = bmi)
bmi_risk <- data %>%summarize(mean_bmi = mean(bmi, na.rm = TRUE),mean_diabetes_risk = mean(diabetes_risk_score, na.rm = TRUE))
print(bmi_risk)
data <- data %>%mutate(gender = gender)
gender_risk <- data %>% group_by(gender) %>% summarize(mean_diabetes_risk = mean(diabetes_risk_score, na.rm = TRUE))
print(gender_risk)
numeric_data <- data %>%select(where(is.numeric))
variables with diabetes_risk_score correlation_result <- numeric_data summarise %>%summarise(across(everything(), ~ cor(.x, diabetes_risk_score, use = "complete.obs") )) %>% pivot_longer(cols = everything(),names_to = "Variable", values_to = "Correlation") %>% filter(Variable !="diabetes_risk_score") %>%arrange(desc(abs(Correlation)))
result <- numeric_data summarise %>%summarise(across(everything(), ~ cor(.x, diabetes_risk_score, use = "complete.obs") )) %>% pivot_longer(cols = everything(),names_to = "Variable", values_to = "Correlation") %>% filter(Variable !="diabetes_risk_score") %>%arrange(desc(abs(Correlation)))
